{
  "name": "contract-user",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "projectType": "library",
  "sourceRoot": "libs/contract/user/src",
  "tags": ["type:contract", "scope:user"],
  "targets": {
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm exec biome check libs/contract/user"
      }
    },
    "format": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm exec biome check --write libs/contract/user"
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm exec tsgo --build libs/contract/user/tsconfig.lib.json"
      },
      "cache": true,
      "outputs": ["{projectRoot}/dist"]
    }
  }
}
