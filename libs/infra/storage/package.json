{
  "name": "@samuelho-dev/infra-storage",
  "version": "0.0.1",
  "type": "module",
  "sideEffects": false,
  "description": "Storage infrastructure with validation, test layers, and resumable upload support",
  "exports": {
    ".": {
      "import": "./src/index.ts",
      "types": "./src/index.ts"
    },
    "./client": {
      "import": "./src/client.ts",
      "types": "./src/client.ts"
    },
    "./client/hooks/use-storage-upload": {
      "import": "./src/lib/client/hooks/use-storage-upload.ts",
      "types": "./src/lib/client/hooks/use-storage-upload.ts"
    },
    "./types": {
      "import": "./src/lib/types.ts",
      "types": "./src/lib/types.ts"
    },
    "./errors": {
      "import": "./src/lib/errors.ts",
      "types": "./src/lib/errors.ts"
    },
    "./validation": {
      "import": "./src/lib/validation.ts",
      "types": "./src/lib/validation.ts"
    }
  },
  "dependencies": {
    "@samuelho-dev/env": "workspace:*",
    "@samuelho-dev/provider-supabase": "workspace:*",
    "react": "*"
  },
  "devDependencies": {
    "@effect/vitest": "catalog:"
  },
  "peerDependencies": {
    "effect": "catalog:"
  }
}
