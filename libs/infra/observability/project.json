{
  "name": "infra-observability",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "projectType": "library",
  "sourceRoot": "libs/infra/observability/src",
  "tags": ["type:infra", "scope:observability"],
  "targets": {
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm exec biome check libs/infra/observability"
      }
    },
    "format": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm exec biome check --write libs/infra/observability"
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm exec tsgo --build libs/infra/observability/tsconfig.lib.json"
      },
      "cache": true,
      "outputs": ["{projectRoot}/dist"]
    },
    "test": {
      "executor": "nx:run-commands",
      "outputs": ["{projectRoot}/coverage"],
      "options": {
        "command": "pnpm exec vitest run --config libs/infra/observability/vitest.config.ts --pool=forks --passWithNoTests",
        "cwd": "{workspaceRoot}"
      }
    }
  }
}
