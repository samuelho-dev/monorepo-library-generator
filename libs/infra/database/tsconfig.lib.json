{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "./dist",
    "declaration": true,
    "declarationMap": true,
    "noEmit": false,
    "composite": true,
    "emitDeclarationOnly": true,
    "rootDir": "src",
    "tsBuildInfoFile": "./dist/tsconfig.lib.tsbuildinfo"
  },
  "include": ["src/**/*.ts", "src/**/*.tsx"],
  "exclude": ["src/**/*.spec.ts", "src/**/*.test.ts", "src/**/*.spec.tsx", "src/**/*.test.tsx"],
  "references": [
    {
      "path": "../../contract/database/tsconfig.lib.json"
    },
    {
      "path": "../../env/tsconfig.lib.json"
    },
    {
      "path": "../../provider/kysely/tsconfig.lib.json"
    },
    {
      "path": "../../provider/supabase/tsconfig.lib.json"
    }
  ]
}
