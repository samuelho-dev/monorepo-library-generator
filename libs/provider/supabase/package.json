{
  "name": "@samuelho-dev/provider-supabase",
  "version": "0.0.1",
  "type": "module",
  "sideEffects": false,
  "description": "Effect-native Supabase provider for auth, storage, realtime, browser, server, and edge clients",
  "exports": {
    ".": {
      "import": "./src/index.ts",
      "types": "./src/index.ts"
    },
    "./client": {
      "import": "./src/client.ts",
      "types": "./src/client.ts"
    },
    "./server": {
      "import": "./src/server.ts",
      "types": "./src/server.ts"
    },
    "./edge": {
      "import": "./src/edge.ts",
      "types": "./src/edge.ts"
    },
    "./types": {
      "import": "./src/types.ts",
      "types": "./src/types.ts"
    },
    "./errors": {
      "import": "./src/lib/errors.ts",
      "types": "./src/lib/errors.ts"
    },
    "./realtime": {
      "import": "./src/lib/realtime.ts",
      "types": "./src/lib/realtime.ts"
    }
  },
  "dependencies": {
    "@samuelho-dev/env": "workspace:*",
    "@supabase/ssr": "*",
    "@supabase/storage-js": "*",
    "@supabase/supabase-js": "*",
    "next": "*",
    "tus-js-client": "*"
  },
  "devDependencies": {
    "vitest": "*"
  },
  "peerDependencies": {
    "effect": "catalog:"
  }
}
