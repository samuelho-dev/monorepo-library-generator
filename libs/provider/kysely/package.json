{
  "name": "@samuelho-dev/provider-kysely",
  "version": "0.0.1",
  "type": "module",
  "sideEffects": false,
  "description": "Effect-native Kysely provider backed by postgres.js",
  "exports": {
    ".": {
      "import": "./src/index.ts",
