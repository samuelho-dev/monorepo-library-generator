{
  "name": "provider-redis",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "projectType": "library",
  "sourceRoot": "libs/provider/redis/src",
  "tags": ["type:provider", "scope:redis"],
  "targets": {
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm exec biome check libs/provider/redis"
      }
    },
    "format": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm exec biome check --write libs/provider/redis"
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm exec tsgo --build libs/provider/redis/tsconfig.lib.json"
      },
      "cache": true,
      "outputs": ["{projectRoot}/dist"]
    },
    "test": {
      "executor": "nx:run-commands",
      "outputs": ["{projectRoot}/coverage"],
      "options": {
        "command": "pnpm exec vitest run --config libs/provider/redis/vitest.config.ts --pool=forks --passWithNoTests",
        "cwd": "{workspaceRoot}"
      }
    }
  }
}
