{
  "$schema": "https://json-schema.org/schema",
  "title": "Standard Contract Library",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]*[a-z0-9]$",
      "description": "Kebab-case library name",
      "$default": { "$source": "argv", "index": 0 }
    },
    "directory": { "type": "string", "description": "Parent directory override" },
    "description": { "type": "string" },
    "tags": { "type": "string", "description": "Comma-separated Nx tags" },
    "modules": {
      "type": "string",
      "description": "Comma-separated module paths, for example form-state,marketing/campaign"
    },
    "capabilities": {
      "type": "string",
      "description": "Comma-separated entities,errors,events,ports,rpc,types roles"
    },
    "dependencies": { "type": "string", "description": "Comma-separated package dependencies" },
    "entrypoints": {
      "type": "string",
      "description": "Comma-separated root,client,server,edge entrypoints"
    },
    "testMode": { "type": "string", "enum": ["none", "unit", "integration"] }
  },
  "required": ["name"]
}
